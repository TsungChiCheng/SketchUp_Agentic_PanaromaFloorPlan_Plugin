# Docker service ports
BACKEND_PORT=8000
DEPTH_SERVICE_PORT=8001

# Docker host user mapping
UID=1000
GID=1000

# Backend logging
BACKEND_LOG_LEVEL=info
DEPTH_SERVICE_LOG_LEVEL=info

# SketchUp plugin connection
ARCHITECH_RENDER_BACKEND_URL=http://127.0.0.1:8000

# Optional SketchUp local paths
# ARCHITECH_EXPORT_DIR=/absolute/path/to/exports
# ARCHITECH_LOCAL_PROJECT_DIR=/absolute/path/to/local/artifact/root
# ARCHITECH_RENDER_ENV_PATH=/absolute/path/to/.env

# Render provider: mock, openai, or gemini
RENDER_PROVIDER=mock

# OpenAI rendering, room rendering, floor-plan plotting, and agent orchestration
FLOOR_PLAN_TOOL_TIMEOUT_SECONDS=180
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1.5
AGENT_MODEL=gpt-4.1-mini

# Optional legacy Gemini rendering provider
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-image

# Depth service
DEPTH_MODEL=depth-anything-v2-metric-indoor-small
